# Public base URL for client-side API calls
NEXT_PUBLIC_API_BASE=http://localhost:3001

# Database connection for Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solarify

# Auth secrets
JWT_SECRET=replace-me-with-strong-secret
JWT_EXPIRES_IN=7d

# Keep Prisma on the library engine locally (avoids accelerate adapter requirement)
PRISMA_CLIENT_ENGINE_TYPE=library

# Port for Next.js dev/server
PORT=3001
